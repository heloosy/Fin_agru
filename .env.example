# AgriSpark 2.0 Environment Variables
# Copy this to .env and fill in your real values

# ── Twilio ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx          # IVR phone number (E.164)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Sandbox or Business

# ── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── App ─────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change_this_to_a_random_secret
BASE_URL=https://your-ngrok-url.ngrok.io  # Or production URL
